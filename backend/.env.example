# ===== LLM 配置 =====
# 填写以下任一 API Key
OPENAI_API_KEY=
# LLM_API_KEY=
DASHSCOPE_API_KEY=

# 可选：自定义端点和模型
# OPENAI_BASE_URL=https://your-gateway/v1
LLM_BASE_URL=https://api-llm.yupaowang.com/v1/chat/completions
# DASHSCOPE_BASE_URL=
LLM_MODEL=qwen3-max

# 可选：运行时调优
LLM_TIMEOUT_SEC=30
LLM_MAX_RETRY=2

# ===== 新鲜度流水线配置 =====
# 流水线版本号（用于缓存键和审计）
FEATURE_SCHEMA_VERSION=v1
GRAPH_VERSION=v1
PROMPT_VERSION_DETECTION=v1
PROMPT_VERSION_NORMALIZATION=v1
PROMPT_VERSION_RISK=v1
PROMPT_VERSION_FINAL=v1

# 各节点模型版本
MODEL_VERSION_DETECTION=qwen3-max
MODEL_VERSION_NORMALIZATION=qwen3-max
MODEL_VERSION_RISK=qwen3-max
MODEL_VERSION_FINAL=qwen3-max

# 词表配置路径（相对于项目根目录）
RECALL_LEXICON_PATH=config/recall_lexicon_v1.json

# 批量执行配置
BATCH_CONCURRENCY=4
BATCH_PARTITION_DATE=

# 可选：飞书 Webhook（运行完成通知）
FEISHU_WEBHOOK=

# ===== 飞书企业登录 =====
FEISHU_AUTH_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://127.0.0.1:8080/api/auth/callback
FEISHU_SESSION_SECRET=
FRONTEND_BASE_URL=http://127.0.0.1:7070
# 多个值用逗号分隔；留空表示允许所有已登录用户访问
FEISHU_ALLOWED_TENANT_KEYS=
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ALLOWED_EMAILS=
# 多个值用逗号分隔；留空表示默认把当前已登录账号视为管理员
FEISHU_ADMIN_OPEN_IDS=
FEISHU_ADMIN_EMAILS=

# ===== ODPS (MaxCompute) 连接配置 =====
ODPS_ACCESS_KEY_ID=
ODPS_ACCESS_KEY_SECRET=
ODPS_PROJECT=yuapo_dev
ODPS_ENDPOINT=http://service.cn.maxcompute.aliyun-inc.com/api
